<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@android:color/white">

    <TextView
        android:id="@+id/tvTituloOpciones"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Opciones de Alimento"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#1565C0"
        android:layout_marginBottom="20dp"
        android:gravity="center"/>

    <Button
        android:id="@+id/btnAnadirALaCompra"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="AÑADIR A LA COMPRA"
        android:backgroundTint="#4CAF50"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="12dp"
        app:cornerRadius="24dp" />

    <Button
        android:id="@+id/btnEditarFecha"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="EDITAR FECHA CADUCIDAD"
        android:backgroundTint="#1565C0"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="12dp"
        app:cornerRadius="24dp" />

    <Button
        android:id="@+id/btnEliminar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ELIMINAR PRODUCTO"
        android:backgroundTint="#D32F2F"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="12dp"
        app:cornerRadius="24dp" />

    <Button
        android:id="@+id/btnNoOpciones"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="CANCELAR"
        android:backgroundTint="#E0E0E0"
        android:textColor="#333333"
        app:cornerRadius="24dp" />

</LinearLayout>